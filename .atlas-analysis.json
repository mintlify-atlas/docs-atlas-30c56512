  "keyFeatures": [
    "Travel commission request and approval workflow",
    "Expense verification with CFDI (XML invoice) validation",
    "Multi-level authorization system (Requestor, Project Manager, Approver, Authorizer)",
    "Payment processing and fund allocation (ministraciones)",
    "Comprehensive reporting for transparency and financial control",
    "Budget item and project management catalogs",
    "Integration with Mexican SAT (Tax Administration Service) for invoice validation",
    "Role-based access control and user permissions",
    "PDF report generation for official documents",
    "Email notifications for workflow events"
  ],
  "publicApiSurface": [
    "Login and authentication system",
    "Solicitud_Comision - Travel commission request form",
    "SolicitudPSP - PSP request form",
    "Comision_Comprobacion - Expense verification interface",
    "ComprobacionAdmin - Administrative expense verification",
